\@writefile{lof}{\contentsline {figure}{\numberline {9}{\ignorespaces Time evolution of the covariance of ${\cal  J}_z$, i.e., the connected piece of the two-time correlation function, $\sigma ^2_{{\cal  J}_z}(t, t+\tau )$, defined in Eq.~\eqref  {eq:connected_piece}, for $t=0$. The correlation decays away on a timescale specified by $T_1 = 1/(\gamma _-^{\rm  loc}+\gamma _+^{\rm  loc})$ as predicted in Eq.~\eqref  {eq:sigma2off}, while the dephasing timescale $T_2$ does not play a role. All solutions have been obtained from solving Eqs.~\eqref  {eq:secondorderapproxCorr} and~\eqref  {eq:mom_sigma22} for $N=10^3$. We observe however that they agree with the full density matrix solution at the $0.1\%$ level.}}{17}{figure.9}\protected@file@percent }
\newlabel{fig:sigma_corr}{{9}{17}{Time evolution of the covariance of ${\cal J}_z$, i.e., the connected piece of the two-time correlation function, $\sigma ^2_{{\cal J}_z}(t, t+\tau )$, defined in Eq.~\eqref {eq:connected_piece}, for $t=0$. The correlation decays away on a timescale specified by $T_1 = 1/(\gamma _-^{\rm loc}+\gamma _+^{\rm loc})$ as predicted in Eq.~\eqref {eq:sigma2off}, while the dephasing timescale $T_2$ does not play a role. All solutions have been obtained from solving Eqs.~\eqref {eq:secondorderapproxCorr} and~\eqref {eq:mom_sigma22} for $N=10^3$. We observe however that they agree with the full density matrix solution at the $0.1\%$ level}{figure.9}{}}
