\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces Steady-state scaling of the collective expectation value $\langle {\cal  J}^2_x\rangle _{|G\rangle }$ as a function of the number of spins $N$, in the presence of neutrino collective interactions only. The nine curves shown here correspond to different values of the dissipation ratio $\gamma _+ / \gamma _-$ as indicated by the colour scale. For a given $\gamma _+ / \gamma _-$, the observable exhibits convergence at $N \gtrsim \mathcal  {O}(10^3)$, with the convergence point shifting to larger values of $N$ as $\gamma _+/\gamma _-$ moves closer to unity. }}{11}{figure.4}\protected@file@percent }
\newlabel{fig:steadystate}{{4}{11}{Steady-state scaling of the collective expectation value $\langle {\cal J}^2_x\rangle _{|G\rangle }$ as a function of the number of spins $N$, in the presence of neutrino collective interactions only. The nine curves shown here correspond to different values of the dissipation ratio $\gamma _+ / \gamma _-$ as indicated by the colour scale. For a given $\gamma _+ / \gamma _-$, the observable exhibits convergence at $N \gtrsim \mathcal {O}(10^3)$, with the convergence point shifting to larger values of $N$ as $\gamma _+/\gamma _-$ moves closer to unity}{figure.4}{}}
