\@writefile{lof}{\contentsline {figure}{\numberline {8}{\ignorespaces \emph  {Left}: Time evolution of $\sigma ^2_{{\cal  J}_z}$ starting from the product state $\vert P\rangle $ (green lines), and from a state with an initial 10/50\% polarisation in the $z$-axis (blue/red lines), with $\gamma _{+}/\gamma _-=0.95$. In all cases, we illustrate in dashed lines the impact of local dephasing at a rate $\gamma _{\phi }^{\rm  loc}=N\gamma _-$. \emph  {Right}: Similar to $\sigma ^2_{{\cal  J}_z}$, but for $\langle J_x^2\rangle $ starting from the fully polarised ground state $\vert G\rangle $ (blue lines), and from a state with 30\% polarisation in the $z$-axis (orange lines). We have set $\gamma _{+}/\gamma _-=0.997$, and assumed local dephasing at a rate $\gamma _{\phi }^{\rm  loc}=N\gamma _-$ for the dashed lines.}}{16}{figure.8}\protected@file@percent }
\newlabel{fig:sigmaz_p}{{8}{16}{\emph {Left}: Time evolution of $\sigma ^2_{{\cal J}_z}$ starting from the product state $\vert P\rangle $ (green lines), and from a state with an initial 10/50\% polarisation in the $z$-axis (blue/red lines), with $\gamma _{+}/\gamma _-=0.95$. In all cases, we illustrate in dashed lines the impact of local dephasing at a rate $\gamma _{\phi }^{\rm loc}=N\gamma _-$. \emph {Right}: Similar to $\sigma ^2_{{\cal J}_z}$, but for $\langle J_x^2\rangle $ starting from the fully polarised ground state $\vert G\rangle $ (blue lines), and from a state with 30\% polarisation in the $z$-axis (orange lines). We have set $\gamma _{+}/\gamma _-=0.997$, and assumed local dephasing at a rate $\gamma _{\phi }^{\rm loc}=N\gamma _-$ for the dashed lines}{figure.8}{}}
